      "parameters": {
        "jsCode": "const item = $input.first();\nlet zipKey = null;\nfor (const key of Object.keys(item.binary || {})) {\n  const name = (item.binary[key].fileName || '').toLowerCase();\n  if (name.endsWith('.zip')) { zipKey = key; break; }\n}\nif (!zipKey) {\n  throw new Error('No se encontró ZIP en el correo ' + item.json.id);\n}\nreturn [{\n  json: { messageId: item.json.id, zipFileName: item.binary[zipKey].fileName },\n  binary: { data: item.binary[zipKey] }\n}];"
      },
      "id": "locate-zip",
      "name": "Localizar ZIP",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
