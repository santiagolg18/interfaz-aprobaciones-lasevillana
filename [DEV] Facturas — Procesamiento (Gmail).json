        "jsCode": "const supplier = $('Buscar Proveedor + Reglas').first().json;\nconst invoice = $input.first().json;\nconst rules = supplier.approval_rules || [];\nconst crypto = require('crypto');\n\nreturn rules.map(rule => ({\n  json: {\n    invoice_id: invoice.id,\n    approver_id: rule.approver_id,\n    approver: rule.approvers,\n    invoice,\n    token: crypto.randomBytes(32).toString('hex'),\n    status: 'pending'\n  }\n}));\n"
