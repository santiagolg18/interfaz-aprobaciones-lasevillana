      "id": "extract-zip",
      "name": "Extraer ZIP",
      "type": "n8n-nodes-base.compression",
      "typeVersion": 1.1,
      "position": [
        880,
        208
      ]
    },
    {
      "parameters": {
        "jsCode": "// Imprime info de TODOS los archivos que salieron del ZIP para diagnosticar\nconst items = $input.all();\nlet pdfBinary = null;\nlet xmlBinary = null;\nconst seenFiles = [];\n\nfor (const item of items) {\n  const keys = Object.keys(item.binary || {});\n  for (const key of keys) {\n    const b = item.binary[key];\n    const fileName = (b.fileName || '').toLowerCase();\n    seenFiles.push({ binaryKey: key, fileName: b.fileName, mimeType: b.mimeType, size: b.fileSize });\n    if (fileName.endsWith('.pdf')) pdfBinary = b;\n    if (fileName.endsWith('.xml')) xmlBinary = b;\n  }\n}\n\n// Output: siempre retorna el JSON con diagnostico, y SOLO pasa al siguiente si encuentra XML\nif (!xmlBinary) {\n  return [{ json: { error: 'No se encontró archivo .xml', seenFiles } }];\n}\n\nreturn [{\n  json: { ok: true, seenFiles },\n  binary: {\n    ...(pdfBinary ? { pdf: pdfBinary } : {}),\n    xml: xmlBinary\n  }\n}];"
      },
      "id": "split-pdf-xml",
      "name": "Separar PDF/XML",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1104,
        208
      ]
    },
    {
      "parameters": {
        "jsCode": "// Leer el XML completo (n8n Cloud almacena binarios grandes externamente)\nconst buffer = await this.helpers.getBinaryDataBuffer(0, 'xml');\nlet xml = buffer.toString('utf-8');\n\n// DIAN envía <AttachedDocument> con la factura real en un CDATA anidado.\nconst cdataRegex = /<!\\[CDATA\\[([\\s\\S]*?)\\]\\]>/g;\nlet match;\nwhile ((match = cdataRegex.exec(xml)) !== null) {\n  if (match[1].includes('<Invoice')) { xml = match[1]; break; }\n}\n\n// Helpers con regex que requiere que el tag termine exactamente (no matchea cbc:IdentificationCode cuando buscamos cbc:ID).\nconst tagRegex = (tag) => new RegExp(`<${tag}(?:\\\\s[^>]*)?>([\\\\s\\\\S]*?)</${tag}>`, 'i');\nconst pick = (tag, src = xml) => {\n  const m = src.match(tagRegex(tag));\n  return m ? m[1].trim() : '';\n};\nconst blockOf = (tag, src = xml) => {\n  const m = src.match(tagRegex(tag));\n  return m ? m[1] : '';\n};\n\n// Campos directos de la Invoice\nconst invoiceNumber = pick('cbc:ID');\nconst issueDate     = pick('cbc:IssueDate');\nconst dueDate       = pick('cbc:PaymentDueDate');\n\n// Monto total\nconst totalsBlock = blockOf('cac:LegalMonetaryTotal');\nconst totalAmount = parseFloat(pick('cbc:PayableAmount', totalsBlock)) || 0;\n\n// Proveedor\nconst supplierBlock = blockOf('cac:AccountingSupplierParty');\nconst taxBlock = blockOf('cac:PartyTaxScheme', supplierBlock);\nconst legalBlock = blockOf('cac:PartyLegalEntity', supplierBlock);\nconst partyNameBlock = blockOf('cac:PartyName', supplierBlock);\n\nconst supplierNit = pick('cbc:CompanyID', taxBlock)\n                 || pick('cbc:CompanyID', legalBlock);\n\nlet supplierName = pick('cbc:RegistrationName', legalBlock)\n                || pick('cbc:RegistrationName', taxBlock)\n                || pick('cbc:Name', partyNameBlock);\n\nreturn [{\n  json: {\n    supplier_nit: String(supplierNit).trim(),\n    supplier_name: String(supplierName).trim(),\n    invoice_number: String(invoiceNumber).trim(),\n    total_amount: totalAmount,\n    issue_date: issueDate,\n    due_date: dueDate,\n    currency: 'COP',\n    email_message_id: $('Gmail Trigger').first().json.id || ''\n  },\n  binary: { pdf: $input.first().binary.pdf }\n}];"
      },
