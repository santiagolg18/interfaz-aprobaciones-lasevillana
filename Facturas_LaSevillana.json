    {
      "parameters": {
        "jsCode": "// Modo: Run Once For All Items.\n// Itera por cada factura entrante, pareando con Normalizar Proveedor\n// por índice (1:1 hasta este punto).\nconst crypto = require('crypto');\nconst out = [];\nconst invoiceItems = $input.all();\nconst supplierItems = $('Normalizar Proveedor').all();\n\nfor (let i = 0; i < invoiceItems.length; i++) {\n  const invoice = invoiceItems[i].json;\n  const supplier = (supplierItems[i] && supplierItems[i].json) || {};\n  const rules = supplier.approval_rules || [];\n  for (const rule of rules) {\n    out.push({\n      json: {\n        invoice_id: invoice.id,\n        approver_id: rule.approver_id,\n        approver: rule.approvers,\n        invoice,\n        token: crypto.randomBytes(32).toString('hex'),\n        status: 'pending'\n      },\n      pairedItem: { item: i }\n    });\n  }\n}\n\nreturn out;\n"
      },
