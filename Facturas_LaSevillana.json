{
  "name": "[DEV] Facturas (Outlook) - La Sevillana — fixes",
  "nodes": [
    {
      "parameters": {
        "jsCode": "// Localiza el/los ZIP(s) entre los adjuntos de CADA correo.\n// Itera por correo (no fusiona) para preservar messageId y attachments por correo.\n\nconst ZIP_MIMES = new Set([\n  'application/zip',\n  'application/x-zip-compressed',\n  'application/x-zip',\n  'multipart/x-zip'\n]);\n\nconst out = [];\n\nfor (const item of $input.all()) {\n  const messageId = (item.json && item.json.id) || null;\n  const binary = item.binary || {};\n  const seen = [];\n  const zips = [];\n\n  for (const key of Object.keys(binary)) {\n    const b = binary[key];\n    const fileName = b.fileName || '';\n    const mimeType = (b.mimeType || '').toLowerCase();\n    const lowerName = fileName.toLowerCase();\n\n    seen.push({ binaryKey: key, fileName, mimeType, size: b.fileSize });\n\n    const isZipByExt  = lowerName.endsWith('.zip');\n    const isZipByMime = ZIP_MIMES.has(mimeType);\n    const isZipOctet  = mimeType === 'application/octet-stream' && isZipByExt;\n\n    if (isZipByExt || isZipByMime || isZipOctet) {\n      zips.push({ binaryKey: key, binaryData: b, fileName });\n    }\n  }\n\n  if (zips.length === 0) {\n    console.log('Correo sin ZIP, se omite. messageId=' + messageId + ' adjuntos=' + JSON.stringify(seen));\n    continue;\n  }\n\n  console.log('Correo ' + messageId + ': ' + zips.length + ' ZIP(s) de ' + seen.length + ' adjuntos. zips=' + JSON.stringify(zips.map(z => z.fileName)));\n\n  for (const z of zips) {\n    out.push({\n      json: {\n        messageId,\n        zipFileName: z.fileName,\n        totalAttachments: seen.length,\n        attachments: seen\n      },\n      binary: { data: z.binaryData }\n    });\n  }\n}\n\nreturn out;\n"
      },
      "id": "2042fd39-efd1-44fd-82b1-863e2a828f5b",
      "name": "Localizar ZIP",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        656,
        208
      ]
    },
    {
      "parameters": {},
      "id": "cc7142fa-6e22-4e51-a375-054aeca4e42e",
      "name": "Extraer ZIP",
      "type": "n8n-nodes-base.compression",
      "typeVersion": 1.1,
      "position": [
        880,
        208
      ]
    },
    {
      "parameters": {
        "jsCode": "// Para cada ZIP extraído, separa su PDF y su XML.\n// Itera por item para emitir UN output por ZIP — no colapsar.\n\nconst out = [];\n\nfor (const item of $input.all()) {\n  const seenFiles = [];\n  let pdfBinary = null;\n  let xmlBinary = null;\n\n  for (const key of Object.keys(item.binary || {})) {\n    const b = item.binary[key];\n    const fileName = (b.fileName || '').toLowerCase();\n    seenFiles.push({ binaryKey: key, fileName: b.fileName, mimeType: b.mimeType, size: b.fileSize });\n    if (fileName.endsWith('.pdf')) pdfBinary = b;\n    if (fileName.endsWith('.xml')) xmlBinary = b;\n  }\n\n  const messageId = (item.json && item.json.messageId) || null;\n  const zipFileName = (item.json && item.json.zipFileName) || null;\n\n  if (!xmlBinary) {\n    console.log('ZIP sin XML, omitido. messageId=' + messageId + ' zip=' + zipFileName + ' files=' + JSON.stringify(seenFiles));\n    continue;\n  }\n\n  out.push({\n    json: {\n      ok: true,\n      messageId,\n      zipFileName,\n      seenFiles\n    },\n    binary: {\n      ...(pdfBinary ? { pdf: pdfBinary } : {}),\n      xml: xmlBinary\n    }\n  });\n}\n\nreturn out;\n"
      },
      "id": "5bd4110e-4116-4bc8-a88e-ede2a601e2fb",
      "name": "Separar PDF/XML",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1104,
        208
      ]
    },
    {
      "parameters": {
        "jsCode": "// Leer el XML completo (n8n Cloud almacena binarios grandes externamente)\nconst buffer = await this.helpers.getBinaryDataBuffer(0, 'xml');\nlet xml = buffer.toString('utf-8');\n\n// DIAN envía <AttachedDocument> con la factura real en un CDATA anidado.\nconst cdataRegex = /<!\\[CDATA\\[([\\s\\S]*?)\\]\\]>/g;\nlet match;\nwhile ((match = cdataRegex.exec(xml)) !== null) {\n  if (match[1].includes('<Invoice')) { xml = match[1]; break; }\n}\n\n// Helpers con regex que requiere que el tag termine exactamente (no matchea cbc:IdentificationCode cuando buscamos cbc:ID).\nconst tagRegex = (tag) => new RegExp(`<${tag}(?:\\\\s[^>]*)?>([\\\\s\\\\S]*?)</${tag}>`, 'i');\nconst pick = (tag, src = xml) => {\n  const m = src.match(tagRegex(tag));\n  return m ? m[1].trim() : '';\n};\nconst blockOf = (tag, src = xml) => {\n  const m = src.match(tagRegex(tag));\n  return m ? m[1] : '';\n};\n\n// Campos directos de la Invoice\nconst invoiceNumber = pick('cbc:ID');\nconst issueDate     = pick('cbc:IssueDate');\nconst dueDate       = pick('cbc:PaymentDueDate');\n\n// Monto total\nconst totalsBlock = blockOf('cac:LegalMonetaryTotal');\nconst totalAmount = parseFloat(pick('cbc:PayableAmount', totalsBlock)) || 0;\n\n// Proveedor\nconst supplierBlock = blockOf('cac:AccountingSupplierParty');\nconst taxBlock = blockOf('cac:PartyTaxScheme', supplierBlock);\nconst legalBlock = blockOf('cac:PartyLegalEntity', supplierBlock);\nconst partyNameBlock = blockOf('cac:PartyName', supplierBlock);\n\nconst supplierNit = pick('cbc:CompanyID', taxBlock)\n                 || pick('cbc:CompanyID', legalBlock);\n\nlet supplierName = pick('cbc:RegistrationName', legalBlock)\n                || pick('cbc:RegistrationName', taxBlock)\n                || pick('cbc:Name', partyNameBlock);\n\nreturn [{\n  json: {\n    supplier_nit: String(supplierNit).trim(),\n    supplier_name: String(supplierName).trim(),\n    invoice_number: String(invoiceNumber).trim(),\n    total_amount: totalAmount,\n    issue_date: issueDate,\n    due_date: dueDate,\n    currency: 'COP',\n    email_message_id: $input.first().json.messageId || ''\n  },\n  binary: { pdf: $input.first().binary.pdf }\n}];"
      },
