      "id": "a8fa4e3f-dbda-4f26-95ad-88f9600dead6",
      "name": "Buscar Proveedor + Reglas",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1776,
        208
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "alwaysOutputData": true,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// Si Buscar Proveedor + Reglas encontró al proveedor por NIT: pásalo tal cual.\n// Si NO (Supabase devolvió [] y con alwaysOutputData llega un item vacío):\n// sintetiza un supplier fallback para que el encargado por defecto reciba el email.\n\nconst DEFAULT_APPROVER = {\n  id: '88403ac2-63bb-4564-983c-5c4c6b7c324f',\n  name: 'Encargado (default)',\n  email: 'santy0218@gmail.com'\n};\n\nconst items = $input.all();\n\n// Un supplier válido tiene id (uuid). Cualquier otra forma (array vacío, objeto sin id,\n// item sintético de alwaysOutputData) se considera \"no encontrado\".\nconst found = items.find(i => {\n  const j = i && i.json;\n  if (!j) return false;\n  if (Array.isArray(j)) return j.length > 0 && j[0] && j[0].id;\n  return !!j.id;\n});\n\nif (found) {\n  const j = found.json;\n  const supplier = Array.isArray(j) ? j[0] : j;\n  return [{ json: supplier }];\n}\n\nconst parsed = $('Parsear XML DIAN').first().json;\n\nreturn [{\n  json: {\n    id: null,\n    nit: parsed.supplier_nit,\n    name: parsed.supplier_name || 'Proveedor sin registro',\n    required_approvals: 1,\n    is_fallback: true,\n    approval_rules: [{\n      id: null,\n      supplier_id: null,\n      approver_id: DEFAULT_APPROVER.id,\n      approval_order: 1,\n      approvers: DEFAULT_APPROVER\n    }]\n  }\n}];"
      },
      "id": "f6b30096-11c8-493e-bb8a-d9c200e8e6b3",
      "name": "Normalizar Proveedor",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2000,
        208
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Modo: Run Once For Each Item.\nconst supplier = $('Normalizar Proveedor').item.json;\nconst parsed = $('Parsear XML DIAN').item.json;\n\nreturn {\n  json: {\n    supplier_id: supplier.id,\n    supplier_nit: parsed.supplier_nit,\n    supplier_name: parsed.supplier_name,\n    invoice_number: parsed.invoice_number,\n    total_amount: parseFloat(parsed.total_amount) || 0,\n    issue_date: parsed.issue_date || null,\n    due_date: parsed.due_date || null,\n    currency: 'COP',\n    required_approvals: parseInt(supplier.required_approvals) || 1,\n    pdf_storage_path: 'invoices/facturas/' + parsed.supplier_nit + '/' + parsed.invoice_number + '.pdf',\n    email_message_id: parsed.email_message_id || ''\n  }\n};\n"
      },
